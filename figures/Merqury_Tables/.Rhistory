setwd("~/Desktop/Merqury_Tables")
library(ggplot2)
library(dplyr)
merqury_stats <- read.delim("merqury_new_stats - Hoja 1.tsv", sep="\t", header=TRUE)
merqury_stats <- read.delim("merqury_new_stats.tsv", sep="\t", header=TRUE)
setwd("~/Desktop/Merqury_Tables")
merqury_stats <- read.delim("merqury_new_stats.tsv", sep="\t", header=TRUE)
merqury_stats <- read.delim("merqury_stats.tsv", sep="\t", header=TRUE)
merqury_stats$N50 <- gsub("\\.", "", merqury_stats$N50)
glimpse(merqury_stats)
merqury_stats <- merqury_stats %>%
mutate(across(-1, ~ as.numeric(gsub("[^0-9.]", "", .))))
glimpse(merqury_stats)
head(merqury_stats)
merqury_stats$Assembly.. <- factor(merqury_stats$Assembly.., levels = merqury_stats$Assembly..)
merqury_stats <- merqury_stats %>%
mutate(Category = case_when(
grepl("flye rfHap paternal", Assembly..) ~ "Nanopore Paternal",
grepl("flye rfHap maternal", Assembly..) ~ "Nanopore Maternal",
grepl("verkko paternal", Assembly..) ~ "Nanopore Paternal",
grepl("verkko maternal", Assembly..) ~ "Nanopore Maternal",
grepl("HiFiasm rfHap paternal", Assembly..) ~ "HiFiasm Paternal",
grepl("HiFiasm rfHap maternal", Assembly..) ~ "HiFiasm Maternal",
grepl("HG002.HiFiasm paternal", Assembly..) ~ "HiFiasm Paternal",
grepl("HG002.HiFiasm maternal", Assembly..) ~ "HiFiasm Maternal",
TRUE ~ "Other"
)) %>%
mutate(Category = factor(Category, levels = c("HiFiasm Maternal", "HiFiasm Paternal",
"Nanopore Maternal", "Nanopore Paternal", "Other")))
merqury_stats <- merqury_stats %>%
mutate(across(-1, ~ as.numeric(gsub("[^0-9.]", "", .))))
glimpse(merqury_stats)
head(merqury_stats)
merqury_stats$Assembly.. <- factor(merqury_stats$Assembly.., levels = merqury_stats$Assembly..)
merqury_stats <- merqury_stats %>%
mutate(Category = case_when(
grepl("flye rfHap paternal", Assembly..) ~ "Nanopore Paternal",
grepl("flye rfHap maternal", Assembly..) ~ "Nanopore Maternal",
grepl("verkko paternal", Assembly..) ~ "Nanopore Paternal",
grepl("verkko maternal", Assembly..) ~ "Nanopore Maternal",
grepl("HiFiasm rfHap paternal", Assembly..) ~ "HiFiasm Paternal",
grepl("HiFiasm rfHap maternal", Assembly..) ~ "HiFiasm Maternal",
grepl("HG002.HiFiasm paternal", Assembly..) ~ "HiFiasm Paternal",
grepl("HG002.HiFiasm maternal", Assembly..) ~ "HiFiasm Maternal",
TRUE ~ "Other"
)) %>%
mutate(Category = factor(Category, levels = c("HiFiasm Maternal", "HiFiasm Paternal",
"Nanopore Maternal", "Nanopore Paternal", "Other")))
ggplot(merqury_stats, aes(x = Assembly.., y = Total.kmers, fill = Category)) +
geom_bar(stat = "identity") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1), legend.position = "none") +
scale_alpha_manual(values = c(0.5, 1 , 0.5, 1 , 0.5 , 1 , 0.5 ,1)) +
scale_y_continuous(labels = scales::comma)+# Ajusta los valores de alpha para cada tipo
labs(title = "Total kmers per Asembly", x = "Assembly", y = "Total kmers")
ggplot(merqury_stats, aes(x = Assembly.., y = Total_kmers, fill = Category)) +
geom_bar(stat = "identity") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1), legend.position = "none") +
scale_alpha_manual(values = c(0.5, 1 , 0.5, 1 , 0.5 , 1 , 0.5 ,1)) +
scale_y_continuous(labels = scales::comma)+# Ajusta los valores de alpha para cada tipo
labs(title = "Total kmers per Asembly", x = "Assembly", y = "Total kmers")
